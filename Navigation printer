#!/usr/bin/env python3

import rclpy
from rclpy.node import Node
from sensor_msgs.msg import NavSatFix


class PioneerGPSPrinter(Node):
    def __init__(self):
        super().__init__('pioneer_gps_printer')

        # Change '/fix' if your GPS topic is different
        self.subscription = self.create_subscription(
            NavSatFix,
            '/fix',
            self.gps_callback,
            10
        )

        self.latest_msg = None

        # Print every 5 seconds
        self.timer = self.create_timer(5.0, self.print_gps)

        self.get_logger().info('Pioneer GPS printer started. Waiting for GPS data...')

    def gps_callback(self, msg: NavSatFix):
        self.latest_msg = msg

    def print_gps(self):
        if self.latest_msg is None:
            self.get_logger().info('No GPS data received yet.')
            return

        lat = self.latest_msg.latitude
        lon = self.latest_msg.longitude
        alt = self.latest_msg.altitude
        status = self.latest_msg.status.status

        self.get_logger().info(
            f'GPS -> lat: {lat:.8f}, lon: {lon:.8f}, alt: {alt:.2f} m, status: {status}'
        )


def main(args=None):
    rclpy.init(args=args)
    node = PioneerGPSPrinter()
    rclpy.spin(node)
    node.destroy_node()
    rclpy.shutdown()


if __name__ == '__main__':
    main()
