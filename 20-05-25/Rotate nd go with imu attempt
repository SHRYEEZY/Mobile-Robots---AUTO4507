# ─────────────────────────── Tunables ────────────────────────────────────────

# Field
AREA_SIZE = 15.0
FIELD_HALF = AREA_SIZE / 2.0

# Ray sweep behaviour
OUTWARD_SWEEP_M = 7.50
RETURN_HOME_TOL_M = 0.25
TARGET_LOG_RADIUS_M = 0.55

# Detection
MAX_DETECT_RANGE = FIELD_HALF * math.sqrt(2)
DETECT_CONE_DEG = 20.0
TARGET_CONE_DEG = 20.0
CHASSIS_MIN_M = 0.25

# Approach / photo
TARGET_STANDOFF_M = 0.70
APPROACH_STANDOFF_M = TARGET_STANDOFF_M
AUTO_SPEED = 0.35

# Bypass after logging target
BYPASS_WIDTH_M = 1.20
BYPASS_FORWARD_M = 1.60

